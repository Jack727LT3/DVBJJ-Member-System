# Supabase — required for live kiosk check-ins and staff dashboard data
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public (browser) — required for /admin magic-link sign-in
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Comma-separated emails allowed to use Full Admin
ADMIN_EMAIL_WHITELIST=owner@yourgym.com

# Optional: enable demo kiosk phone paths in production (testing only)
# KIOSK_DEMO_MEMBER=true
# KIOSK_DEMO_GUEST_PHONE=7273891434
